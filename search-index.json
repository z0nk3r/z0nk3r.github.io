---
layout: null
permalink: /search-index.json
---
{% comment %}
This file is large (the full text of every syscall reference table included
verbatim, ~780KB raw) - by design, not an oversight. Full excerpt-only
indexing was considered and rejected: search needs to match syscall names
that only appear in table bodies, not in any post/reference excerpt.
normalize_whitespace above collapses the runs of whitespace strip_html
leaves behind from converting table markup to text, which is a real,
zero-behavior-change shrink. Beyond that, this is fetched only when a
search query is actually submitted (not on every page load), and GitHub
Pages serves it gzip-compressed, which takes repetitive table text down to
roughly a tenth of this size on the wire.
{% endcomment %}
[
{% assign first = true %}
{% for post in site.posts %}
  {% unless first %},{% endunless %}{% assign first = false %}
  {% assign result_author = post.author | default: site.author %}
  {% assign author_doc = site.authors | where: "name", result_author | first %}
  {
    "type": "post",
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: site.date_format | jsonify }},
    "author": {{ result_author | jsonify }},
    "authorAvatar": {{ author_doc.avatar | jsonify }},
    "image": {{ post.image | relative_url | jsonify }},
    "excerpt": {{ post.excerpt | strip_html | normalize_whitespace | jsonify }},
    "content": {{ post.content | strip_html | normalize_whitespace | jsonify }}
  }
{% endfor %}
{% for reference in site.references %}
  {% unless first %},{% endunless %}{% assign first = false %}
  {
    "type": "reference",
    "title": {{ reference.title | jsonify }},
    "url": {{ reference.url | relative_url | jsonify }},
    "date": null,
    "author": null,
    "authorAvatar": null,
    "image": {{ reference.image | relative_url | jsonify }},
    "excerpt": {{ reference.excerpt | strip_html | normalize_whitespace | jsonify }},
    "content": {{ reference.content | strip_html | normalize_whitespace | jsonify }}
  }
{% endfor %}
{% for topic in site.tutorial_topics %}
  {% unless first %},{% endunless %}{% assign first = false %}
  {
    "type": "tutorial-topic",
    "title": {{ topic.title | jsonify }},
    "url": {{ topic.url | relative_url | jsonify }},
    "date": null,
    "author": null,
    "authorAvatar": null,
    "context": null,
    "image": {{ topic.image | relative_url | jsonify }},
    "excerpt": {{ topic.description | strip_html | normalize_whitespace | jsonify }},
    "content": {{ topic.content | strip_html | normalize_whitespace | jsonify }}
  }
{% endfor %}
{% for chapter in site.tutorials %}
  {% unless first %},{% endunless %}{% assign first = false %}
  {% assign ch_topic = site.tutorial_topics | where: "topic", chapter.topic | first %}
  {
    "type": "tutorial-chapter",
    "title": {{ chapter.title | jsonify }},
    "url": {{ chapter.url | relative_url | jsonify }},
    "date": null,
    "author": null,
    "authorAvatar": null,
    "context": {{ ch_topic.title | jsonify }},
    "image": null,
    "excerpt": {{ chapter.excerpt | strip_html | normalize_whitespace | jsonify }},
    "content": {{ chapter.content | strip_html | normalize_whitespace | jsonify }}
  }
{% endfor %}
]
